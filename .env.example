# ============================================================
# Inventory Discrepancy Agent — Environment Variables
# cp .env.example .env  then fill in your values
# Never commit .env to version control
# ============================================================

# Shopify
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_SECRET=your_webhook_hmac_secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
AGENT_MODEL=claude-sonnet-4-6

# Redis
REDIS_URL=redis://redis:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://agent_user:secret@postgres:5432/inventory_discrepancy_agent

# Google Sheets (audit trail)
GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/gcp-sa.json
AUDIT_SPREADSHEET_ID=your_spreadsheet_id_here

# Slack (requires Slack App with interactivity enabled for approval buttons)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_ALERTS_CHANNEL=#inventory-alerts
SLACK_SIGNING_SECRET=your_slack_signing_secret

# LangFuse tracing (optional — leave blank to disable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# Sentry error monitoring (optional — leave blank to disable)
SENTRY_DSN=

# Agent behaviour
# "live" = full automation | "shadow" = log-only, skip all inventory mutations
AGENT_MODE=shadow
# Discrepancy % below this is ignored by the scheduler
DISCREPANCY_THRESHOLD_PCT=5.0

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# Admin API
ADMIN_API_KEY=

# App
APP_ENV=production
LOG_LEVEL=INFO
PORT=8000
APPROVAL_EXPIRY_HOURS=24
